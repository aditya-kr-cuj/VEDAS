{
  "name": "vedas",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-tenant SaaS platform for coaching institutes",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @vedas/api",
    "build": "npm run build --workspace @vedas/api",
