{
  "name": "@vedas/api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:migrate": "node ./src/db/migrations/run-migrations.js",
    "db:seed-super-admin": "tsx ./src/db/seed-super-admin.ts",
    "test": "node --loader tsx --test src/__tests__/*.test.ts",
    "test:jest": "jest",
    "attendance:alerts": "tsx ./src/scripts/attendance-alerts.ts",
    "fees:reminders": "tsx ./src/scripts/fee-reminders.ts",
    "performance:summary": "tsx ./src/scripts/performance-summary.ts",
    "email:worker": "tsx ./src/scripts/email-worker.ts",
    "sms:worker": "tsx ./src/scripts/sms-worker.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.12.0",
    "pdfkit": "^0.15.0",
    "archiver": "^6.0.2",
    "razorpay": "^2.9.4",
    "resend": "^3.3.0",
    "@aws-sdk/client-s3": "^3.732.0",
    "@aws-sdk/lib-storage": "^3.732.0",
    "@aws-sdk/s3-request-presigner": "^3.732.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.11.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/jest": "^29.5.12",
    "@types/supertest": "^2.0.16",
    "@types/node": "^22.7.4",
    "@types/pg": "^8.11.10",
    "eslint": "^9.11.1",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
